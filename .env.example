# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database Connection (Format: postgresql://user:password@host:port/database)
DATABASE_URL=postgresql://lexai:lexai_password@postgres:5432/lexaidb

# Redis Cache Connection
REDIS_URL=redis://redis:6379/0

# Authentication
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_jwt_signing_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# External APIs
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_key_here

# Observability
SENTRY_DSN=https://your_sentry_public_key@o0.ingest.sentry.io/0